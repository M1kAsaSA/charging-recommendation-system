.container {
  padding: 0;
  background-color: #f5f7fa;
  background-image:
    radial-gradient(600px 200px at 10% -10%, rgba(0, 82, 217, 0.10), transparent 60%),
    radial-gradient(500px 200px at 90% 0%, rgba(54, 207, 201, 0.10), transparent 55%);
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #0044c7 0%, #0a7cff 60%, #33b2ff 100%);
  color: #fff;
  padding: 30px 20px 22px;
  margin-bottom: 16px;
  box-shadow: 0 6px 16px rgba(0, 82, 217, 0.25);
}

.header-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 6px;
  letter-spacing: 0.2px;
}

.header-subtitle {
  font-size: 13px;
  opacity: 0.9;
}

/* 站点列表 */
.station-list {
  padding: 0 16px 18px;
}

.station-item {
  background: #fff;
  padding: 0;
  border-radius: 12px;
  margin-bottom: 12px;
  overflow: hidden;
  border: 1px solid #eef1f6;
  box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.station-item:active {
  transform: translateY(1px);
  box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
}

.station-card {
  padding: 22px 16px 16px;
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

/* 排名徽章 */
.rank-badge {
  position: absolute;
  top: 10px;
  left: 16px;
  background: linear-gradient(135deg, #ff7a7a 0%, #f44336 100%);
  color: #fff;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  white-space: nowrap;
}

/* 站点信息 */
.station-info {
  flex: 1;
  margin-top: 6px;
}

.name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.name {
  font-size: 16px;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.score-badge {
  background-color: #fff6e5;
  color: #d97706;
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  white-space: nowrap;
  margin-left: 8px;
}

.address {
  font-size: 13px;
  color: #64748b;
  margin-bottom: 10px;
  line-height: 1.4;
}

/* 标签行 */
.tags-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.tag {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  white-space: nowrap;
}

.tag.price {
  background-color: #fff1f2;
  color: #e11d48;
}

.tag.distance {
  background-color: #e0f2fe;
  color: #0284c7;
}

.nav-row {
  margin-top: 10px;
}

.nav-btn {
  display: inline-block;
  padding: 6px 12px;
  border-radius: 8px;
  background: #0a66ff;
  color: #fff;
  font-size: 12px;
  font-weight: 600;
}

.nav-btn:active {
  background: #0048c2;
}

/* 右侧箭头 */
.arrow-icon {
  font-size: 20px;
  color: #cbd5f5;
  margin-top: 6px;
  align-self: center;
  margin-left: 8px;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60px 20px;
  background-color: transparent;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.6;
}

.empty-text {
  font-size: 16px;
  color: #666;
  font-weight: 500;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 13px;
  color: #999;
}