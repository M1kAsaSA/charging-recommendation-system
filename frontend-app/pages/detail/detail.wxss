.container {
  padding: 20px;
  background-color: #f5f7fa;
  background-image:
    radial-gradient(500px 200px at 10% -10%, rgba(0, 82, 217, 0.10), transparent 60%),
    radial-gradient(500px 200px at 90% 0%, rgba(54, 207, 201, 0.12), transparent 55%);
  min-height: 100vh;
}

/* 站点头部 */
.station-header {
  background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
  padding: 18px;
  border-radius: 12px;
  margin-bottom: 12px;
  border: 1px solid #eef1f6;
  box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
}

.station-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  margin-bottom: 4px;
}

.station-address {
  font-size: 13px;
  color: #64748b;
  margin-bottom: 6px;
}

.pile-count {
  font-size: 12px;
  color: #94a3b8;
}

/* 地图卡片 */
.map-card {
  background-color: #fff;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 12px;
  border: 1px solid #eef1f6;
  box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
}

.map-view {
  width: 100%;
  height: 210px;
}

.nav-panel {
  margin-bottom: 16px;
  display: flex;
}

.btn-nav {
  background: linear-gradient(135deg, #36cfc9 0%, #0a66ff 100%);
  color: #fff;
}

/* 快速操作按钮 */
.action-panel {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
}

.btn {
  flex: 1;
  padding: 14px 0;
  border-radius: 10px;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  border: none;
  outline: none;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 6px;
  box-shadow: 0 6px 16px rgba(15, 23, 42, 0.12);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.btn::after {
  border: none;
}

.btn:active {
  transform: translateY(1px);
  box-shadow: 0 4px 10px rgba(15, 23, 42, 0.12);
}

.btn-scan {
  background: linear-gradient(135deg, #36cfc9 0%, #0a66ff 100%);
}

.icon {
  font-size: 20px;
}

/* 部分标题 */
.section-title {
  font-size: 14px;
  font-weight: 700;
  border-left: 3px solid #0052d9;
  padding-left: 12px;
  margin-bottom: 12px;
  color: #334155;
  margin-top: 10px;
}

/* 电桩列表 */
.pile-list {
  background-color: #fff;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #eef1f6;
  box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
}

.pile-item {
  padding: 12px 14px;
  border-bottom: 1px solid #f1f5f9;
}

.pile-item:last-child {
  border-bottom: none;
}

.pile-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.pile-left {
  flex: 1;
}

.pile-code-tag {
  display: inline-block;
  background-color: #f1f5f9;
  color: #334155;
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 600;
  font-size: 12px;
  margin-bottom: 6px;
}

.pile-details {
  font-size: 13px;
  color: #666;
}

.pile-type {
  color: #666;
}

.pile-right {
  display: flex;
  align-items: center;
}

/* 状态徽章 */
.status-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
}

.status-badge.idle {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1px solid #b7eb8f;
}

.status-badge.busy {
  background-color: #e6f7ff;
  color: #1890ff;
  border: 1px solid #91d5ff;
}

.status-badge.fault {
  background-color: #fff2e8;
  color: #fa541c;
  border: 1px solid #ffbb96;
}

.status-badge.offline {
  background-color: #f5f5f5;
  color: #999;
  border: 1px solid #ddd;
}

.status-icon {
  font-size: 14px;
}

.status-text {
  font-size: 12px;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 40px 20px;
  background-color: #fff;
  border-radius: 8px;
  color: #999;
}

.empty-icon {
  font-size: 40px;
  margin-bottom: 10px;
  opacity: 0.6;
}

.empty-text {
  font-size: 14px;
  color: #666;
  font-weight: 500;
}