.action-panel { display: flex; gap: 20rpx; margin-bottom: 40rpx; }
.btn { flex: 1; padding: 20rpx 0; border-radius: 12rpx; color: #fff; font-size: 32rpx; font-weight: bold; border: none; outline: none; display: flex; justify-content: center; align-items: center; }
.btn::after { border: none; }
.btn-scan { background: linear-gradient(135deg, #36cfc9 0%, #0052d9 100%); box-shadow: 0 8rpx 20rpx rgba(0,82,217,0.3); }
.btn-stop { background: linear-gradient(135deg, #ff7875 0%, #f5222d 100%); box-shadow: 0 8rpx 20rpx rgba(245,34,45,0.3); }
.icon { margin-right: 12rpx; font-size: 36rpx; }

.section-title { font-size: 32rpx; font-weight: bold; border-left: 8rpx solid #0052d9; padding-left: 16rpx; margin-bottom: 24rpx; color: #333; }

.pile-list { background: #fff; border-radius: 16rpx; padding: 0 24rpx; }
.pile-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1px solid #f0f0f0; }
.pile-item:last-child { border-bottom: none; }
.code { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.type { font-size: 24rpx; color: #999; }
.status { font-size: 26rpx; font-weight: bold; padding: 6rpx 16rpx; border-radius: 30rpx; }
.status.idle { background: #f6ffed; color: #52c41a; border: 1px solid #b7eb8f; }
.status.busy { background: #e6f7ff; color: #1890ff; border: 1px solid #91d5ff; }
.status.fault { background: #fff2e8; color: #fa541c; border: 1px solid #ffbb96; }
.empty { text-align: center; padding: 40rpx 0; color: #999; font-size: 28rpx; }