<view class="container">
  <view class="action-panel">
    <button class="btn btn-scan" bindtap="scanToStart">
      <text class="icon">📷</text> 模拟扫码充电
    </button>
    <button class="btn btn-stop" bindtap="stopAndSettle">
      <text class="icon">⏹</text> 模拟拔枪结算
    </button>
  </view>

  <view class="section-title">该电站下的充电桩</view>
  
  <view class="pile-list">
    <view class="pile-item" wx:for="{{piles}}" wx:key="id">
      <view class="pile-info">
        <view class="code">桩编号: {{item.pileCode}}</view>
        <view class="type">类型: {{item.type == 1 ? '快充' : '慢充'}} ({{item.power}}kW)</view>
      </view>
      <view class="status {{item.status == 1 ? 'idle' : (item.status == 2 ? 'busy' : 'fault')}}">
        {{item.status == 1 ? '空闲中' : (item.status == 2 ? '充电中' : '故障')}}
      </view>
    </view>
    <view wx:if="{{piles.length === 0}}" class="empty">该电站暂无充电桩</view>
  </view>
</view>